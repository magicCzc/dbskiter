# ============================================================
# 数据库配置文件示例
# ⚠️ 重要：
#   1. 复制此文件为 .env 并填入实际值
#   2. 确保 .env 已添加到 .gitignore
#   3. 不要提交真实配置到版本控制！
# ============================================================

# ============================================================
# 数据库实例配置格式说明
# ============================================================
# 使用 DB_{别名}_* 格式配置多个数据库实例
# 别名建议使用有意义的名字，如：jump, prod, orcl 等
#
# 连接时使用：dbskiter --database=jump sql execute "SELECT 1"
# ============================================================

# ============================================================
# MySQL - 示例库1
# ============================================================
DB_JUMP_HOST=your_mysql_host
DB_JUMP_PORT=3306
DB_JUMP_USER=your_username
DB_JUMP_PASSWORD=your_password
DB_JUMP_NAME=your_database
DB_JUMP_DIALECT=mysql+pymysql
DB_JUMP_POOL_SIZE=5

# ============================================================
# MySQL - 示例库2
# ============================================================
DB_CHENZC_HOST=your_mysql_host
DB_CHENZC_PORT=3306
DB_CHENZC_USER=your_username
DB_CHENZC_PASSWORD=your_password
DB_CHENZC_NAME=your_database
DB_CHENZC_DIALECT=mysql+pymysql
DB_CHENZC_POOL_SIZE=5

# ============================================================
# Oracle - 示例库
# ============================================================
DB_ORCL_HOST=your_oracle_host
DB_ORCL_PORT=1521
DB_ORCL_USER=your_username
DB_ORCL_PASSWORD=your_password
DB_ORCL_SERVICE=your_service
DB_ORCL_DIALECT=oracle+jdbc
DB_ORCL_JDBC_DRIVER=ojdbc8.jar

# ============================================================
# SQL Server - 示例库
# ============================================================
DB_MSSQL_HOST=your_sqlserver_host
DB_MSSQL_PORT=1433
DB_MSSQL_USER=your_username
DB_MSSQL_PASSWORD=your_password
DB_MSSQL_NAME=your_database
DB_MSSQL_DIALECT=mssql+pyodbc

# ============================================================
# PostgreSQL - 示例库
# ============================================================
DB_PG_HOST=your_postgres_host
DB_PG_PORT=5432
DB_PG_USER=your_username
DB_PG_PASSWORD=your_password
DB_PG_NAME=your_database
DB_PG_DIALECT=postgresql+psycopg2
DB_PG_POOL_SIZE=5

# ============================================================
# ClickHouse - 示例库
# ============================================================
DB_CH_HOST=your_clickhouse_host
DB_CH_PORT=8123
DB_CH_USER=your_username
DB_CH_PASSWORD=your_password
DB_CH_NAME=your_database
DB_CH_DIALECT=clickhouse+http

# ============================================================
# SQLite - 示例库
# ============================================================
# SQLite 是文件数据库，host 填写 .db 文件的绝对路径
DB_SQLITE_HOST=C:/data/your_database.db
DB_SQLITE_PORT=0
DB_SQLITE_USER=
DB_SQLITE_PASSWORD=
DB_SQLITE_NAME=your_database
DB_SQLITE_DIALECT=sqlite+pysqlite

# ============================================================
# 安全策略配置
# ============================================================
# 可选值: production | development | testing
# production: 最严格，默认只读，危险操作需 --force
# development: 标准模式，允许写操作但需确认
# testing: 宽松模式，仅阻止 CRITICAL 操作
# ============================================================
DBSKITER_ENV=production

# ============================================================
# Prometheus 监控配置（示例）
# ============================================================
PROMETHEUS_URL=http://your_prometheus_server:9090

# ============================================================
# Zabbix 监控配置（示例）
# ============================================================
ZABBIX_URL=http://your_zabbix_server/api_jsonrpc.php
ZABBIX_USER=your_zabbix_user
ZABBIX_PASSWORD=your_zabbix_password
